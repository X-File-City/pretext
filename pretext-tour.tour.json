{
  "id": "pretext-codebase-tour",
  "title": "Pretext: Browser-Accurate Text Layout in Pure JS",
  "description": "A guided tour of Pretext's architecture — from the core measurement engine to multilingual corpus testing and interactive demos.",
  "version": "1.0.0",
  "steps": [
    {
      "id": "overview",
      "title": "The Big Picture",
      "description": "Pretext is a pure JavaScript library that measures multiline text layout without touching the DOM. It replaces expensive layout-reflow calls with cached canvas measurements and pure arithmetic, unlocking virtualization, masonry layouts, and layout-shift-free rendering. The codebase is organized into a tight core engine, browser accuracy infrastructure, multilingual test corpora, benchmarks, and interactive demos.",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "core-dirs",
          "name": "Key Areas",
          "color": "#3b82f6",
          "items": [
            { "path": "src", "type": "directory" },
            { "path": "pages", "type": "directory" },
            { "path": "corpora", "type": "directory" },
            { "path": "scripts", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ],
      "focusDirectory": ""
    },
    {
      "id": "core-engine",
      "title": "The Core Engine",
      "description": "The heart of Pretext lives in four files. The layout module is the resize hot path — pure arithmetic, no DOM, no allocations. The analysis and measurement modules handle one-time prepare work: segmentation, glue rules, canvas caching, and browser-profile shims. The line-break module is the line-walking core shared by all layout APIs.",
      "focusDirectory": "src",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "hot-path",
          "name": "Layout Hot Path",
          "color": "#ef4444",
          "items": [
            { "path": "src/layout.ts", "type": "file" }
          ],
          "opacity": 0.8,
          "renderStrategy": "border"
        },
        {
          "id": "prepare-phase",
          "name": "Prepare Phase",
          "color": "#f59e0b",
          "items": [
            { "path": "src/analysis.ts", "type": "file" },
            { "path": "src/measurement.ts", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "line-breaking",
          "name": "Line Breaking",
          "color": "#8b5cf6",
          "items": [
